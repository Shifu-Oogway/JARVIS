# ---- Core ----
JARVIS_ENVIRONMENT=development
JARVIS_DEBUG=true
JARVIS_JWT_SECRET=change-me-in-production

# ---- Datastores ----
JARVIS_DATABASE_URL=postgresql+asyncpg://jarvis:jarvis@postgres:5432/jarvis
JARVIS_REDIS_URL=redis://redis:6379/0

# ---- NVIDIA NIM ----
# Hosted NVIDIA endpoint (build.nvidia.com) or your self-hosted NIM gateway.
JARVIS_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
JARVIS_NIM_API_KEY=
# Optional: comma-separated extra NIM gateway URLs for load balancing / failover.
JARVIS_NIM_EXTRA_ENDPOINTS=

# ---- Obsidian ----
JARVIS_OBSIDIAN_VAULT_PATH=/data/vault

# ---- CORS ----
JARVIS_CORS_ORIGINS=http://localhost:3000
